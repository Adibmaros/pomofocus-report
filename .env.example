# Database
DATABASE_URL="postgresql://user:password@host:port/dbname?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:port/dbname"

# Nuxt Auth Session (Minimum 32 chars)
NUXT_SESSION_PASSWORD="your-super-long-random-session-password-32"

# Google OAuth
NUXT_OAUTH_GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
NUXT_OAUTH_GOOGLE_CLIENT_SECRET="GOCSPX-xxx"

# AI Configuration
GROQ_API_KEY="gsk_xxx"

# Supabase Storage (For PDF hosting)
SUPABASE_URL="https://xxx.supabase.co"
SUPABASE_SERVICE_KEY="your-service-role-key"
